# ─── Firebase (Firestore) ──────────────────────────────────────────────────────
#
# Option A – single JSON blob (easiest for local dev via .env.local):
#   Paste the full contents of your Firebase service account JSON here.
#   Download it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
#
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'

# Option B – individual fields (better for Vercel / Railway / Render env dashboards
#   that don't support multi-line values):
#
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com"
# Paste the private key exactly as it appears in the JSON, including newlines.
# In most deployment dashboards you can paste the raw value; in .env files you
# must escape newlines as \n (one long string, no literal line breaks).
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ─── Auth ─────────────────────────────────────────────────────────────────────
AUTH_PASSWORD="your-strong-password"
AUTH_SECRET="generate-a-long-random-string"
