rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── users collection ──────────────────────────────────────────────────────
    // Only the authenticated user can read their own document.
    // Role updates must go through a trusted server (Admin SDK bypasses rules).
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
                       && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
    }

    // ── folders & questions ───────────────────────────────────────────────────
    // Any authenticated user can read/write. Role-based restrictions will be
    // added here once role field is established in the users collection.
    match /folders/{id} {
      allow read, write: if request.auth != null;
    }

    match /questions/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
